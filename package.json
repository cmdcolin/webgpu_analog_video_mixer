{
  "name": "phosphene",
  "private": true,
  "version": "0.0.0",
  "description": "Real-time NTSC / VHS / composite-video glitch simulator in WebGPU compute shaders.",
  "license": "MIT",
  "homepage": "https://cmdcolin.github.io/phosphene/",
  "repository": {
    "type": "git",
    "url": "https://github.com/cmdcolin/phosphene.git"
  },
  "keywords": [
    "webgpu",
    "ntsc",
    "vhs",
    "composite-video",
    "analog-video",
    "crt",
    "glitch",
    "video-synth",
    "wgsl",
    "compute-shader"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --cache --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "dot -Tsvg docs/pipeline-simple.dot -o docs/pipeline-simple-light.svg && dot -Tsvg -Ecolor=#9aa4b2 -Efontcolor=#9aa4b2 docs/pipeline-simple.dot -o docs/pipeline-simple-dark.svg && dot -Tsvg docs/pipeline.dot -o docs/pipeline-light.svg && dot -Tsvg -Ecolor=#9aa4b2 -Efontcolor=#9aa4b2 docs/pipeline.dot -o docs/pipeline-dark.svg"
  },
  "dependencies": {
    "prettier": "^3.9.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@eslint-react/eslint-plugin": "^5.17.1",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "@webgpu/types": "^0.1.64",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "puppeteer-core": "^25.3.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
